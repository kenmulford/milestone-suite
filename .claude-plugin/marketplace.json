    { "name": "milestone-designer",           "source": { "source": "url", "url": "https://github.com/kenmulford/milestone-designer.git" } },
    { "name": "milestone-feeder",             "source": { "source": "url", "url": "https://github.com/kenmulford/milestone-feeder.git" } },
    { "name": "milestone-driver",             "source": { "source": "url", "url": "https://github.com/kenmulford/milestone-driver.git" } },
    { "name": "milestone-coherence-reviewer", "source": { "source": "url", "url": "https://github.com/kenmulford/milestone-coherence-reviewer.git" } }
  ]
}
