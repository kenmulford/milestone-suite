# Suite tooling — per-run scratch (milestone-driver + milestone-feeder)
.milestone-driver-*
.milestone-feeder*

# Suite config under .milestone-config/ is tracked (driver.json, feeder.json);
# these per-clone scratch artifacts are not:
.milestone-config/triage-cache.json
.milestone-config/*-notice
.milestone-config/worktrees/

# Per-developer Claude Code settings. A project-level .claude/settings.json (shared,
# repo-relative permissions) stays trackable; settings.local.json is per-clone and
# routinely holds machine-absolute paths — never commit it.
.claude/settings.local.json

# macOS
.DS_Store
